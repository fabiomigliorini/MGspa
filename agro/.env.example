# Exemplo das variáveis usadas pelo app.
# O .env real é um symlink pra ../negocios/.env (master compartilhado dos apps MGspa).

# --- Credenciais OAuth (usadas no logout / revoke) ---
CLIENT_ID=
CLIENT_SECRET=

# --- APIs ---
API_URL=https://api-dev.mgpapelaria.com.br/api/
