# --- Apps MGspa (menu de apps) ---
SISTEMA_URL=https://sistema-dev.mgpapelaria.com.br
NEGOCIOS_URL=https://negocios-dev.mgpapelaria.com.br:9900
NOTAS_URL=https://sistema-dev.mgpapelaria.com.br:8082
CONTAS_URL=https://sistema-dev.mgpapelaria.com.br:8086
PESSOAS_URL=https://sistema-dev.mgpapelaria.com.br:8081
ESTOQUE_URL=https://sistema-dev.mgpapelaria.com.br:8087
AGRO_URL=https://sistema-dev.mgpapelaria.com.br:8088
