APP_NAME="MGspa API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Cuiaba
APP_URL=https://api-dev.mgpapelaria.com.br
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco compartilhado mgsis
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=mgsis
DB_USERNAME=mgsis
DB_PASSWORD=mgsis
DB_SCHEMA=mgsis

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=.mgpapelaria.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Redis (session + cache + queue). REDIS_HOST=redis quando rodando via docker-compose.yaml.
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

MAIL_MAILER=log
MAIL_FROM_ADDRESS="naoresponda@mgpapelaria.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Auth (paridade MGAuth — mesmo client UUID do banco mgsis.oauth_clients)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_COOKIE_DOMAIN=.mgpapelaria.com.br
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_DEFAULT_REDIRECT=https://sistema-dev.mgpapelaria.com.br

# Backend legado para proxy fallback no Marco 3+ (rotas ainda não migradas
# são repassadas pro MGspa/laravel antigo). Apontar pra RAIZ do host
# legacy — `$request->path()` já inclui o prefixo "api/...".
LEGACY_API_URL=https://api-mgspa-dev.mgpapelaria.com.br
LEGACY_PROXY_ENABLED=true
LEGACY_VERIFY_SSL=false
