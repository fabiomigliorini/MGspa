APP_NAME="MGspa API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://api-dev.mgpapelaria.com.br
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco compartilhado mgsis
DB_CONNECTION=pgsql
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=mgsis
DB_USERNAME=mgsis
DB_PASSWORD=mgsis
DB_SCHEMA=mgsis

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.mgpapelaria.com.br
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="naoresponda@mgpapelaria.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Auth (paridade MGAuth — mesmo client UUID do banco mgsis.oauth_clients)
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_COOKIE_DOMAIN=.mgpapelaria.com.br
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=none
AUTH_DEFAULT_REDIRECT=https://sistema-dev.mgpapelaria.com.br

# Backend legado para proxy fallback (Marcos 3+, ainda não usado)
LEGACY_API_URL=https://api-mgspa-dev.mgpapelaria.com.br/api
